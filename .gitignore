# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (the local one holds secrets; the example is a safe template)
.env*
!.env.example

# packaged desktop app output (multi-hundred-MB .app / .dmg)
/dist-app

# local tooling / agent config
/.claude
/CLAUDE_CONTEXT.md

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
