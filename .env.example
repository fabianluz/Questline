# --- Database ---
DATABASE_URL="postgres://questline:questline_dev_only@localhost:5432/questline"

# --- Better Auth ---
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-me-with-a-32-byte-base64-secret"
BETTER_AUTH_URL="http://localhost:3000"

# --- Public app URL (used by browser-side auth client) ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- AI Advisor (local LLM via Ollama) ---
# 100% on-device. Setup:
#   brew install --cask ollama   # menu bar app, auto-starts
#   ollama pull qwen2.5:14b     # ~9GB, one-time download
# Then click "Ask the Guide" on any Epic detail page.
# Default is qwen2.5:14b — best fit for 24GB Apple Silicon (strong tool-calling
# + JSON fidelity). Lighter option if you're tight on RAM: qwen2.5:7b (~4.7GB).
# Smaller (sub-7B) options trade quality on structured tool calls.
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="qwen2.5:14b"
